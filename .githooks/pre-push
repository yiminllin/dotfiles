#!/bin/bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

opencode run "Based on nvim/.config/nvim/lua/plugins/, tmux/.tmux.conf, fish/.config/fish/config.fish, and install.sh, update PLUGINS.md for plugin additions/removals only. If there are no plugin-related changes, don't update anything. Keep the change as minimal as possible." --agent dotfile-documenter

if ! git diff --quiet -- PLUGINS.md; then
  git add PLUGINS.md
fi

if ! git diff --cached --quiet -- PLUGINS.md; then
  cat >&2 <<'EOF'
pre-push: PLUGINS.md was updated and staged.
Review the staged change, commit it, then push again.
EOF
  exit 1
fi
