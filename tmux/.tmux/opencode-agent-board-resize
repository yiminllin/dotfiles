#!/usr/bin/env bash

set -euo pipefail

separator=$'\034'

resize_window_boards() {
  local window=$1
  local pane_id board_flag

  [[ -n "$window" ]] || return 0
  [[ "$(tmux display-message -p -t "$window" '#{window_zoomed_flag}' 2>/dev/null || true)" != 1 ]] || return 0

  while IFS="$separator" read -r pane_id board_flag; do
    [[ "$board_flag" == 1 ]] || continue
    tmux resize-pane -t "$pane_id" -y 1 >/dev/null 2>&1 || true
  done < <(
    tmux list-panes -t "$window" -F "#{pane_id}${separator}#{@opencode_agent_board}" 2>/dev/null || true
  )
}

case ${1:-apply-window} in
  apply-window)
    resize_window_boards "${2:-$(tmux display-message -p '#{window_id}')}"
    ;;
  apply-all)
    while IFS= read -r window_id; do
      resize_window_boards "$window_id"
    done < <(tmux list-windows -a -F '#{window_id}' 2>/dev/null || true)
    ;;
  *)
    printf 'usage: %s [apply-window [window] | apply-all]\n' "${0##*/}" >&2
    exit 2
    ;;
esac
