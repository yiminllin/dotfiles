#!/usr/bin/env bash

set -euo pipefail

separator=$'\034'

pane_rows() {
  tmux list-panes -a -F "#{pane_id}${separator}#{session_name}:#{window_id}${separator}#{session_name}${separator}#{pane_current_command}${separator}#{pane_start_command}${separator}#{pane_title}" \
    | while IFS="$separator" read -r pane_id target_window session_name current_cmd start_cmd pane_title; do
        [[ "$current_cmd" == opencode || "$start_cmd" == *opencode* ]] || continue

        local content status sort_key

        pane_title="${pane_title//$'\t'/ }"
        pane_title="${pane_title//$'\n'/ }"
        pane_title="${pane_title//$'\r'/ }"
        pane_title="${pane_title#OC | }"
        pane_title="${pane_title#OpenCode | }"
        pane_title="${pane_title#"${pane_title%%[![:space:]]*}"}"
        pane_title="${pane_title%"${pane_title##*[![:space:]]}"}"
        pane_title="${pane_title:-OpenCode}"

        content="$(tmux capture-pane -p -t "$pane_id" -S -4 -E - 2>/dev/null || true)"
        content="${content//$'\r'/}"
        status='\033[32mIDLE\033[0m'
        sort_key=2

        if [[ "${content,,}" == *"esc interrupt"* ]]; then
          status='\033[31mRUNNING\033[0m'
          sort_key=1
        fi

        printf '  %b %s\tpane\t%s\t%s\t%s\t%s\n' \
          "$status" \
          "$pane_title" \
          "$pane_id" \
          "$target_window" \
          "$session_name" \
          "$sort_key"
      done
}

with_headers() {
  local current_session=""

  while IFS=$'\t' read -r display row_type pane_id target_window session_name sort_key; do
    if [[ "$session_name" != "$current_session" ]]; then
      current_session="$session_name"
      printf '%s\theader\t\t\t%s\t\n' \
        "$session_name" \
        "$session_name"
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$display" \
      "$row_type" \
      "$pane_id" \
      "$target_window" \
      "$session_name" \
      "$sort_key"
  done
}

rows="$(pane_rows | sort -t$'\t' -k5,5 -k6,6 -k1,1 | with_headers)"

if [[ -z "$rows" ]]; then
  echo "No OpenCode panes found."
  exit 0
fi

selected="$(printf '%s\n' "$rows" | fzf --ansi --cycle --delimiter=$'\t' --with-nth=1 --height=60% --layout=reverse --header='Select OpenCode pane' || true)"

if [[ -z "$selected" ]]; then
  exit 0
fi

IFS=$'\t' read -r _ row_type pane_id target_window _ <<< "$selected"

if [[ "$row_type" != pane ]]; then
  exit 0
fi

tmux run-shell -b "sleep 0.05; tmux switch-client -t \"$target_window\"; tmux select-pane -t \"$pane_id\""
