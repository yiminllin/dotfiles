#!/usr/bin/env bash

set -euo pipefail

separator=$'\034'
refresh_interval=0.5
current_pane=${TMUX_PANE:-$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)}
current_client=""
current_session_id=""
current_session_name=""
current_window_id=""
progress_renderer="$HOME/.config/opencode/scripts/opencode_progress_render.py"
progress_refresh_seconds=${OPENCODE_AGENT_BOARD_PROGRESS_REFRESH_SECONDS:-30}
progress_snapshot_limit=${OPENCODE_AGENT_BOARD_SNAPSHOT_LIMIT:-10}
rendered_content=""
saved_tty_state=""

declare -a rows=()
declare -a target_panes=()
declare -a target_sessions=()
declare -a target_windows=()

refresh_current_context() {
  current_client=""
  current_session_id=""
  current_session_name=""
  current_window_id=""

  [[ -n "$current_pane" ]] || return 0
  current_client=$(tmux display-message -p -t "$current_pane" '#{client_tty}' 2>/dev/null || true)
  current_session_id=$(tmux display-message -p -t "$current_pane" '#{session_id}' 2>/dev/null || true)
  current_session_name=$(tmux display-message -p -t "$current_pane" '#{session_name}' 2>/dev/null || true)
  current_window_id=$(tmux display-message -p -t "$current_pane" '#{window_id}' 2>/dev/null || true)
}

trim() {
  local value=$1
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

shorten() {
  local value=$1
  local max_length=22

  if (( ${#value} > max_length )); then
    printf '%s…' "${value:0:max_length}"
  else
    printf '%s' "$value"
  fi
}

context_segment() {
  local context=""

  [[ "${OPENCODE_AGENT_BOARD_DEBUG:-}" == 1 ]] || return 0
  [[ -n "$current_session_name" ]] && context=$(shorten "$current_session_name")
  [[ -n "$current_client" ]] && context+="${context:+ }$current_client"
  [[ -n "$context" ]] || return 0
  printf '\033[2m%s\033[0m  ║  ' "$context"
}

setup_tty() {
  [[ -t 0 ]] || return 0
  saved_tty_state=$(stty -g 2>/dev/null || true)
  [[ -n "$saved_tty_state" ]] || return 0
  stty -echo -icanon min 1 time 0 2>/dev/null || saved_tty_state=""
}

restore_tty() {
  [[ -n "$saved_tty_state" && -t 0 ]] || return 0
  stty "$saved_tty_state" 2>/dev/null || true
  saved_tty_state=""
}

read_key() {
  local __key_var=$1

  printf -v "$__key_var" '%s' ""
  if [[ -t 0 ]]; then
    IFS= read -rsn1 -t "$refresh_interval" "$__key_var"
    return $?
  fi

  if IFS= read -rsn1 -t 0 "$__key_var"; then
    return 0
  fi
  sleep "$refresh_interval"
  return 1
}

agent_name() {
  local pane_id=$1
  local pane_title=$2
  local name=${3:-}

  name=$(trim "$name")
  pane_title=$(trim "$pane_title")
  shorten "${name:-${pane_title:-UNNAMED $pane_id}}"
}

agent_state() {
  local pane_id=$1
  local content

  content=$(tmux capture-pane -p -t "$pane_id" -S -6 -E - 2>/dev/null || true)
  content="${content//$'\r'/}"

  if [[ "${content,,}" == *"esc interrupt"* ]]; then
    printf 'RUN'
  else
    printf 'WAIT'
  fi
}

state_label() {
  case $1 in
    RUN) printf '\033[31m󰐊 RUN\033[0m' ;;
    *) printf '\033[32m󰔟 WAIT\033[0m' ;;
  esac
}

progress_segment() {
  local segment

  [[ "${OPENCODE_AGENT_BOARD_SHOW_PROGRESS:-}" == 1 ]] || return 0
  command -v python3 >/dev/null 2>&1 || return 0
  [[ -f "$progress_renderer" ]] || return 0
  segment=$(
    python3 "$progress_renderer" \
      --mode statusline \
      --width 76 \
      --refresh \
      --refresh-seconds "$progress_refresh_seconds" \
      --snapshot-limit "$progress_snapshot_limit" \
      2>/dev/null || true
  )
  [[ -n "$segment" ]] || return 0
  printf '%s' "$segment"
}

is_opencode_values() {
  local pane_title=$1
  local current_cmd=$2
  local start_cmd=$3

  [[ "$current_cmd" == opencode || "$start_cmd" == *opencode* || "$pane_title" == "OC | "* || "$pane_title" == opencode* ]]
}

collect_agents() {
  local -a waiting=()
  local -a running=()
  local entry is_board pane_id pane_index pane_title session_id session_name window_id window_index current_cmd start_cmd state name

  while IFS="$separator" read -r pane_id session_id session_name window_id window_index pane_index is_board name pane_title current_cmd start_cmd; do
    [[ "$is_board" == 1 ]] && continue
    is_opencode_values "$pane_title" "$current_cmd" "$start_cmd" || continue

    state=$(agent_state "$pane_id")
    entry="$session_name$separator$window_index$separator$pane_index$separator$pane_id$separator$session_id$separator$window_id$separator$state$separator$(agent_name "$pane_id" "$pane_title" "$name")"

    if [[ "$state" == WAIT ]]; then
      waiting+=("$entry")
    else
      running+=("$entry")
    fi
  done < <(
    tmux list-panes -a \
      -F "#{pane_id}${separator}#{session_id}${separator}#{session_name}${separator}#{window_id}${separator}#{window_index}${separator}#{pane_index}${separator}#{@opencode_agent_board}${separator}#{@opencode_agent_name}${separator}#{pane_title}${separator}#{pane_current_command}${separator}#{pane_start_command}" \
      | sort -t"$separator" -k3,3 -k5,5n -k6,6n
  )

  ((${#waiting[@]})) && printf '%s\n' "${waiting[@]}"
  ((${#running[@]})) && printf '%s\n' "${running[@]}"
}

render() {
  local index=1
  local context index_label name name_label pane_id progress row session_id state window_id

  rows=()
  target_panes=()
  target_sessions=()
  target_windows=()

  while IFS="$separator" read -r _ _ _ pane_id session_id window_id state name; do
    [[ -n "$pane_id" ]] || continue

    if [[ -n "$current_window_id" && "$window_id" == "$current_window_id" ]]; then
      index_label=$(printf '\033[4m[%s]\033[0m' "$index")
      name_label=$(printf '\033[4m%s\033[0m' "$name")
    else
      index_label=$(printf '\033[1m[%s]\033[0m' "$index")
      name_label=$name
    fi

    rows+=("$index_label $(state_label "$state") $name_label")
    target_panes[$index]=$pane_id
    target_sessions[$index]=$session_id
    target_windows[$index]=$window_id
    ((index++))

    [[ $index -le 9 ]] || break
  done < <(collect_agents)

  progress=$(progress_segment)
  context=$(context_segment)
  if [[ ${#rows[@]} -eq 0 ]]; then
    rendered_content="${context}no OpenCode agents"
    if [[ -n "$progress" ]]; then
      rendered_content+="  ║  $progress"
    fi
    return 0
  fi

  rendered_content="${context}${rows[0]}"
  for row in "${rows[@]:1}"; do
    rendered_content+="  ║  $row"
  done
  if [[ -n "$progress" ]]; then
    rendered_content+="  ║  $progress"
  fi
  return 0
}

jump_to_agent() {
  local key=$1
  local pane_id=${target_panes[$key]:-}
  local session_id=${target_sessions[$key]:-}
  local window_id=${target_windows[$key]:-}

  [[ -n "$pane_id" && -n "$session_id" && -n "$window_id" ]] || return 0

  if [[ -n "$current_client" ]]; then
    if tmux switch-client -c "$current_client" -t "$session_id:$window_id" 2>/dev/null; then
      "$HOME/.tmux/opencode-pane-focus-main" "$window_id" "$pane_id" 2>/dev/null || true
    else
      tmux display-message -t "$current_pane" 'Agent Board: target tmux client is no longer available' 2>/dev/null || true
    fi
    return 0
  fi

  if [[ -n "$current_session_id" && "$session_id" == "$current_session_id" ]]; then
    tmux select-window -t "$window_id" 2>/dev/null || return 0
    "$HOME/.tmux/opencode-pane-focus-main" "$window_id" "$pane_id" 2>/dev/null || true
    return 0
  fi

  tmux display-message -t "$current_pane" 'Agent Board: cannot resolve current client for cross-session jump' 2>/dev/null || true
}

last_rendered_content=""

setup_tty
trap restore_tty EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

while true; do
  refresh_current_context
  render
  if [[ "$rendered_content" != "$last_rendered_content" ]]; then
    printf '\033[H\033[2K%s' "$rendered_content"
    last_rendered_content=$rendered_content
  fi

  key=""
  if read_key key; then
    case "$key" in
      q) tmux kill-pane -t "$current_pane"; exit 0 ;;
      [1-9]) refresh_current_context; jump_to_agent "$key" ;;
    esac
  fi
done
