#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: $(basename "$0") <path>" >&2
    exit 1
fi

workspace=$1
workspace_name=$(basename "$workspace" | tr . _)

create_window() {
    local name=$1
    local command=${2:-}

    tmux new-window -t "$workspace_name" -n "$name" -c "$workspace"

    if [[ -n "$command" ]]; then
        tmux send-keys -t "$workspace_name:$name" "$command" C-m
    fi
}

if ! tmux has-session -t="$workspace_name" 2>/dev/null; then
    tmux new-session -ds "$workspace_name" -n code -c "$workspace"
    tmux send-keys -t "$workspace_name:code" 'nvim' C-m

    create_window git 'lazygit'
    create_window run
    create_window shell
    create_window agent 'opencode'

    tmux select-window -t "$workspace_name:code"
fi

if [[ -n ${TMUX:-} ]]; then
    tmux switch-client -t "$workspace_name"
else
    tmux attach-session -t "$workspace_name"
fi
