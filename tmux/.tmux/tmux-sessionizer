#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: $(basename "$0") <path>" >&2
    exit 1
fi

workspace=$1
workspace_name=$(basename "$workspace" | tr . _)

shell_window="îž• shell"
agent_window="ó°š© agent"
code_window="îš® code"

create_window() {
    local name=$1
    local command=${2:-}

    tmux new-window -t "$workspace_name" -n "$name" -c "$workspace"

    if [[ -n "$command" ]]; then
        tmux send-keys -t "$workspace_name:$name" "$command" C-m
    fi
}

if ! tmux has-session -t="$workspace_name" 2>/dev/null; then
    tmux new-session -ds "$workspace_name" -n "$shell_window" -c "$workspace"
    create_window "$agent_window" 'opencode'
    create_window "$code_window"

    tmux select-window -t "$workspace_name:$agent_window"
fi

if [[ -n ${TMUX:-} ]]; then
    tmux switch-client -t "$workspace_name"
else
    tmux attach-session -t "$workspace_name"
fi
