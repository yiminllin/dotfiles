#!/usr/bin/env bash

set -euo pipefail

board_script="$HOME/.tmux/opencode-agent-board"
session_name=${1:-$(tmux display-message -p '#{session_name}')}

if [[ "$(tmux show-option -gqv @opencode_agent_board_disabled)" == 1 ]]; then
  exit 0
fi

ensure_board() (
  local window_id=$1
  local active_pane board_flag lock_name new_pane

  lock_name="opencode_agent_board_${window_id//[^A-Za-z0-9]/_}"
  tmux wait-for -L "$lock_name"
  trap 'tmux wait-for -U "$lock_name"' EXIT

  if [[ "$(tmux display-message -p -t "$window_id" '#{window_name}')" == "session-finder" ]]; then
    return 0
  fi

  while IFS= read -r start_command; do
    [[ "$start_command" == *tmux-session-finder* || "$start_command" == *tmux-sessionizer* ]] && return 0
  done < <(tmux list-panes -t "$window_id" -F '#{pane_start_command}')

  while IFS= read -r board_flag; do
    [[ "$board_flag" == 1 ]] && return 0
  done < <(tmux list-panes -t "$window_id" -F '#{@opencode_agent_board}')

  active_pane=$(tmux display-message -p -t "$window_id" '#{pane_id}')
  new_pane=$(tmux split-window -t "$window_id" -b -f -v -l 2 -d -P -F '#{pane_id}' "$board_script")
  tmux set-option -pt "$new_pane" @opencode_agent_board 1 >/dev/null
  tmux select-pane -t "$new_pane" -T 'Agent Board'
  tmux select-pane -t "$active_pane"
)

while IFS= read -r window_id; do
  ensure_board "$window_id"
done < <(tmux list-windows -t "$session_name" -F '#{window_id}')
