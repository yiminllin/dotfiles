#!/usr/bin/env bash

set -euo pipefail

separator=$'\034'
board_script="$HOME/.tmux/opencode-agent-board"
session_name=${1:-$(tmux display-message -p '#{session_name}')}
target_window=${2:-}

if [[ "$(tmux show-option -gqv @opencode_agent_board_disabled)" == 1 ]]; then
  exit 0
fi

is_board_values() {
  local board_flag=$1
  local pane_title=$2
  local start_command=$3

  [[ "$board_flag" == 1 || "$pane_title" == "Agent Board" || "$start_command" == *"$board_script"* ]]
}

ensure_board() (
  local window_id=$1
  local active_pane board_flag lock_name new_pane pane_title start_command start_commands window_name

  lock_name="opencode_agent_board_${window_id//[^A-Za-z0-9]/_}"
  tmux wait-for -L "$lock_name"
  trap 'tmux wait-for -U "$lock_name"' EXIT

  if ! window_name=$(tmux display-message -p -t "$window_id" '#{window_name}' 2>/dev/null); then
    return 0
  fi

  if [[ "$window_name" == "session-finder" ]]; then
    return 0
  fi

  if ! start_commands=$(tmux list-panes -t "$window_id" -F '#{pane_start_command}' 2>/dev/null); then
    return 0
  fi

  while IFS= read -r start_command; do
    [[ "$start_command" == *tmux-session-finder* || "$start_command" == *tmux-sessionizer* ]] && return 0
  done <<< "$start_commands"

  while IFS="$separator" read -r board_flag pane_title start_command; do
    is_board_values "$board_flag" "$pane_title" "$start_command" && return 0
  done < <(
    tmux list-panes -t "$window_id" \
      -F "#{@opencode_agent_board}${separator}#{pane_title}${separator}#{pane_start_command}" 2>/dev/null || true
  )

  if ! active_pane=$(tmux display-message -p -t "$window_id" '#{pane_id}' 2>/dev/null); then
    return 0
  fi

  if ! new_pane=$(tmux split-window -t "$window_id" -b -f -v -l 1 -d -P -F '#{pane_id}' "$board_script" 2>/dev/null); then
    return 0
  fi

  tmux set-option -pt "$new_pane" @opencode_agent_board 1 >/dev/null 2>&1 || true
  tmux select-pane -t "$new_pane" -T 'Agent Board' 2>/dev/null || true
  tmux select-pane -t "$active_pane" 2>/dev/null || true
)

remove_inactive_boards() {
  local keep_window=$1
  local board_flag kept_board=0 pane_id pane_title start_command window_id

  while IFS= read -r window_id; do
    while IFS="$separator" read -r pane_id board_flag pane_title start_command; do
      is_board_values "$board_flag" "$pane_title" "$start_command" || continue

      if [[ "$window_id" == "$keep_window" && "$kept_board" == 0 ]]; then
        kept_board=1
        continue
      fi

      tmux kill-pane -t "$pane_id" 2>/dev/null || true
    done < <(
      tmux list-panes -t "$window_id" \
        -F "#{pane_id}${separator}#{@opencode_agent_board}${separator}#{pane_title}${separator}#{pane_start_command}" 2>/dev/null || true
    )
  done < <(tmux list-windows -t "$session_name" -F '#{window_id}' 2>/dev/null || true)
}

if [[ -z "$target_window" ]]; then
  target_window=$(tmux display-message -p -t "$session_name:" '#{window_id}' 2>/dev/null || true)
fi

[[ -n "$target_window" ]] || exit 0
ensure_board "$target_window"
remove_inactive_boards "$target_window"
