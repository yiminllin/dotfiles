{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "skill": "allow",
    "external_directory": {
      "*": "ask",
      "~/notes/": "allow",
      "~/notes/**": "allow",
      "~/dotfiles/": "allow",
      "~/dotfiles/**": "allow",
      "~/.config/": "allow",
      "~/.config/**": "allow",
      "/tmp": "allow",
      "/tmp/**": "allow",
      "/private/tmp": "allow",
      "/private/tmp/**": "allow",
      "/Systems/.phoenix/": "allow",
      "/Systems/.phoenix/**": "allow",
      "/Systems/.agents/": "allow",
      "/Systems/.agents/**": "allow"
    },
    "doom_loop": "ask",
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*.pem": "ask",
      "*.key": "ask"
    },
    "edit": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*.pem": "ask",
      "*.key": "ask"
    },
    "bash": {
      "*": "allow",
      "sudo *": "ask",
      "git push --force": "ask",
      "git push --force *": "ask",
      "git push * --force": "ask",
      "git push * --force *": "ask",
      "git reset --hard": "ask",
      "git reset --hard *": "ask",
      "git clean": "ask",
      "git clean *": "ask"
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "medium"
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "instructions": [
    "README.md",
    "AGENTS.md",
    "~/dotfiles/opencode/.config/opencode/user-profile.yaml"
  ],
  "default_agent": "orchestrator",
  "model": "openai/gpt-5.5",
  "autoupdate": true
}
