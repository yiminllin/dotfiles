{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "everforest",
  "keybinds": {
    "leader": "alt+space",
    "command_list": "<leader>h",
    "messages_toggle_conceal": "<leader>c",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d"
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  }
}
